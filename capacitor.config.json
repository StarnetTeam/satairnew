{
	"appId": "com.satair.app",
	"appName": "Sat Air",
	"webDir": "build",
	"android": {
		"textZoom": 100
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 2000,
			"launchAutoHide": true,
			"backgroundColor": "#0f172a",
			"androidSplashResourceName": "splash",
			"showSpinner": false,
			"androidScaleType": "CENTER_CROP",
			"splashFullScreen": true,
			"splashImmersive": true
		},
		"LocalNotifications": {
			"smallIcon": "ic_stat_notify",
			"iconColor": "#3b82f6"
		}
	}
}
